# Gitignore for ESP-IDF v6 projects

# Build directory
/build/

# Generated configuration files
/sdkconfig
/sdkconfig.old

# Component build artifacts
/components/.idf/
/components/__pycache__/
managed_components/

# IDF tools directory
/.espressif/

# Generated files
*.bin
*.elf
*.map
*.bin.*  # Bootloader binaries
*.factory.bin
*.img
*.flasher.conf
*.flasher_args.json
*.flasher_project.json
*.hex
*.list
*.rom
*.tab.*  # Symbol table files
*.pem
*.der

# Compiler/IDE generated
*.o
*.a
*.out
*.exe
*.d
*.orig
*.rej

# Logs
*.log
logs/

# Python cache
*.pyc
*.pyo
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# User-specific files
*.user
*.sln.docstates
*.workspace
*.suo
*.user
*.uvproj
*.uvopt

# CMake
CMakeCache.txt
CMakeFiles/
CMakeScripts/
CMakeLists.txt.user
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json

# Language server
.ccls-cache/
.clangd/

# Coverage reports
coverage/
*.gcov
*.lcov
*.info

# Documentation
/doc/_build/

# Testing
/.nyc_output/
/coverage/
/htmlcov/
.tox/

# Misc
*.cache
*.tmp
*.temp
/tmp/
/temp/
